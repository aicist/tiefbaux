DATABASE_URL=sqlite:///./tiefbaux.db
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite-preview
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional SMTP (outbound inquiries)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=demo@gmail.com
SMTP_PASSWORD=app-password
SMTP_FROM_EMAIL=demo@gmail.com
SMTP_FROM_NAME=Fassbender Tenten GmbH
SMTP_USE_TLS=true
SMTP_DEMO_MODE=true
SMTP_DEMO_RECIPIENTS=demo@gmail.com
SMTP_DEMO_SUBJECT_PREFIX=[DEMO]

# Demo inbound mailbox polling (Gmail IMAP)
INBOUND_EMAIL_ENABLED=false
INBOUND_EMAIL_POLL_MINUTES=2
INBOUND_EMAIL_IMAP_HOST=imap.gmail.com
INBOUND_EMAIL_IMAP_PORT=993
INBOUND_EMAIL_IMAP_USER=demo@gmail.com
INBOUND_EMAIL_IMAP_PASSWORD=app-password
INBOUND_EMAIL_IMAP_FOLDER=INBOX
INBOUND_EMAIL_IMAP_USE_SSL=true
INBOUND_EMAIL_MARK_SEEN=true
INBOUND_EMAIL_NEW_LV_KEYWORDS=lv,leistungsverzeichnis,ausschreibung,anfrage,angebotsanfrage
INBOUND_EMAIL_OFFER_KEYWORDS=angebot,lieferantenangebot,preisangebot,rueckmeldung,rückmeldung
